generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum LessonType {
  EXPLANATION
  PRACTICE
  QUIZ
  REVIEW
}

enum LessonActivityType {
  NUMERIC
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
}

enum LessonBlockType {
  THEORY
  EXAMPLE
  VISUAL
  PRACTICE_INTRO
  SUMMARY
}

model User {
  id               String                 @id @default(cuid())
  name             String
  email            String                 @unique
  passwordHash     String
  role             Role
  active           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  accessibility    AccessibilityProfile?
  attempts         Attempt[]
  sessions         Session[]
  trackProgress    TrackProgress[]
  tutorLinks       TutorStudent[]         @relation("TutorRelation")
  studentLinks     TutorStudent[]         @relation("StudentRelation")
  passwordResets   PasswordResetToken[]
  sentInvitations  Invitation[]           @relation("InvitationCreator")
  tutorInvitations Invitation[]           @relation("InvitationTutor")
}

model Invitation {
  id              String    @id @default(cuid())
  email           String
  role            Role
  tokenHash       String    @unique
  invitedByUserId String
  tutorId         String?
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  invitedBy       User      @relation("InvitationCreator", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  tutor           User?     @relation("InvitationTutor", fields: [tutorId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expiresAt])
  @@index([invitedByUserId])
  @@index([tutorId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TutorStudent {
  id         String   @id @default(cuid())
  tutorId    String
  studentId  String
  createdAt  DateTime @default(now())
  tutor      User     @relation("TutorRelation", fields: [tutorId], references: [id], onDelete: Cascade)
  student    User     @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([tutorId, studentId])
  @@index([tutorId])
  @@index([studentId])
}

model AccessibilityProfile {
  id             String   @id @default(cuid())
  fontSize       Int      @default(16)
  spacing        Int      @default(24)
  guidance       Boolean  @default(false)
  minimal        Boolean  @default(false)
  reducedMotion  Boolean  @default(false)
  focusMode      String   @default("calmo")
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SkillTrack {
  id                    String        @id @default(cuid())
  slug                  String        @unique
  name                  String
  description           String
  shortDescription      String        @default("")
  longDescriptionMd     String        @default("")
  estimatedTime         String
  difficulty            String        @default("")
  targetAudience        String        @default("")
  learningOutcomesMd    String        @default("")
  prerequisiteSummaryMd String        @default("")
  status                ContentStatus @default(DRAFT)
  modules               TrackModule[]
  lessons               Lesson[]
  progress              TrackProgress[]
}

model TrackModule {
  id               String        @id @default(cuid())
  skillTrackId     String
  skillTrack       SkillTrack    @relation(fields: [skillTrackId], references: [id], onDelete: Cascade)
  title            String
  descriptionMd    String        @default("")
  estimatedMinutes Int?
  orderIndex       Int
  status           ContentStatus @default(DRAFT)
  lessons          Lesson[]

  @@index([skillTrackId])
}

model Lesson {
  id               String         @id @default(cuid())
  skillTrackId     String
  skillTrack       SkillTrack     @relation(fields: [skillTrackId], references: [id], onDelete: Cascade)
  trackModuleId    String
  trackModule      TrackModule    @relation(fields: [trackModuleId], references: [id], onDelete: Cascade)
  title            String
  summary          String         @default("")
  contentMd        String         @default("")
  instructionMd    String         @default("")
  teacherNotesMd   String         @default("")
  lessonType       LessonType     @default(PRACTICE)
  estimatedMinutes Int?
  prompt           String
  story            String
  explanation      String
  answer           Int
  level            String
  goal             String
  tip              String
  orderIndex       Int
  status           ContentStatus  @default(DRAFT)
  blocks           LessonBlock[]
  activities       LessonActivity[]
  attempts         Attempt[]

  @@index([trackModuleId])
}

model LessonBlock {
  id         String          @id @default(cuid())
  lessonId   String
  lesson     Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type       LessonBlockType
  title      String          @default("")
  contentMd  String          @default("")
  orderIndex Int

  @@index([lessonId])
}

model LessonActivity {
  id                  String             @id @default(cuid())
  lessonId            String
  lesson              Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type                LessonActivityType
  instructionMd       String             @default("")
  answerKey           String
  optionsJson         String             @default("[]")
  hintMd              String             @default("")
  feedbackCorrectMd   String             @default("")
  feedbackIncorrectMd String             @default("")
  orderIndex          Int
  attempts            Attempt[]

  @@index([lessonId])
}

model TrackProgress {
  id            String      @id @default(cuid())
  userId        String
  skillTrackId  String
  lessonIndex   Int         @default(0)
  correct       Int         @default(0)
  attempts      Int         @default(0)
  streak        Int         @default(0)
  mastery       Int         @default(0)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillTrack    SkillTrack  @relation(fields: [skillTrackId], references: [id], onDelete: Cascade)

  @@unique([userId, skillTrackId])
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  activityId  String
  answer      String
  isCorrect   Boolean
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  activity    LessonActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
